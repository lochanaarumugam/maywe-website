---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Button from '../../components/Button.astro';
import StoryCard from '../../components/StoryCard.astro';
import Placeholder from '../../components/Placeholder.astro';
import VideoEmbed from '../../components/VideoEmbed.astro';
import { site } from '../../config';

export const getStaticPaths = (async () => {
  const stories = (await getCollection('stories')).filter((s) => !s.data.draft);
  return stories.map((story) => ({ params: { slug: story.id }, props: { story } }));
}) satisfies GetStaticPaths;

const { story } = Astro.props;
const { Content } = await render(story);
const readMin = Math.max(1, Math.round((story.body ?? '').split(/\s+/).length / 200));
const dateStr = story.data.date.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });

const all = (await getCollection('stories')).filter((s) => !s.data.draft);
const related = all
  .filter((s) => s.id !== story.id && s.data.category === story.data.category)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const url = new URL(`/stories/${story.id}`, site.url).href;
const shareText = encodeURIComponent(story.data.title);
const share = {
  whatsapp: `https://wa.me/?text=${shareText}%20${encodeURIComponent(url)}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(url)}`,
  twitter: `https://twitter.com/intent/tweet?text=${shareText}&url=${encodeURIComponent(url)}`,
  email: `mailto:?subject=${shareText}&body=${encodeURIComponent(url)}`,
};
---

<BaseLayout title={story.data.title} description={story.data.excerpt} ogImage={story.data.cover}>
  <article>
    <!-- POST HEADER -->
    <div class="bg-green-50">
      <div class="max-w-3xl mx-auto px-4 pt-14 pb-8">
        <a href="/stories" class="text-sm text-green-700 font-semibold hover:text-green-900">← All stories</a>
        <span class="inline-block mt-4 text-xs font-semibold uppercase tracking-wide text-green-700 bg-green-100 rounded-full px-3 py-1">{story.data.category}</span>
        <h1 class="text-3xl md:text-5xl mt-3">{story.data.title}</h1>
        <p class="mt-4 text-muted">By {story.data.author} · {dateStr} · {readMin} min read</p>
      </div>
    </div>

    <!-- FEATURED MEDIA: video if provided, else featured image -->
    {
      story.data.video ? (
        <div class="max-w-4xl mx-auto px-4 -mt-2">
          <VideoEmbed url={story.data.video} title={story.data.title} />
        </div>
      ) : (
        <div class="max-w-5xl mx-auto px-4 -mt-2">
          <Placeholder src={story.data.cover} label="Featured photo" alt={story.data.coverAlt ?? story.data.title} ratio="16/9" class="rounded-2xl shadow-[var(--shadow-card)]" />
        </div>
      )
    }

    <!-- CONTENT -->
    <div class="max-w-2xl mx-auto px-4 py-12">
      <div class="prose-maywe">
        <Content />
      </div>

      {
        story.data.tags.length > 0 && (
          <div class="mt-8 flex flex-wrap gap-2">
            {story.data.tags.map((t) => (
              <span class="text-xs bg-green-50 text-green-700 rounded-full px-3 py-1">#{t}</span>
            ))}
          </div>
        )
      }

      <!-- SHARE -->
      <div class="mt-8 border-t border-black/10 pt-6">
        <p class="text-sm font-semibold mb-2">Share this story</p>
        <div class="flex flex-wrap gap-3 text-sm">
          <a href={share.whatsapp} target="_blank" rel="noopener" class="underline text-green-700">WhatsApp</a>
          <a href={share.facebook} target="_blank" rel="noopener" class="underline text-green-700">Facebook</a>
          <a href={share.twitter} target="_blank" rel="noopener" class="underline text-green-700">Twitter/X</a>
          <a href={share.email} class="underline text-green-700">Email</a>
        </div>
      </div>
    </div>

    <!-- INLINE DONATE CTA -->
    <div class="bg-saffron-100">
      <div class="max-w-3xl mx-auto px-4 py-10 text-center">
        <p class="text-xl font-display mb-4">Inspired by this story? Help us do more.</p>
        <Button href="/donate" variant="accent">Donate Now →</Button>
      </div>
    </div>

    <!-- RELATED -->
    {
      related.length > 0 && (
        <div class="max-w-7xl mx-auto px-4 py-16">
          <h2 class="text-2xl mb-8">Related stories</h2>
          <div class="grid md:grid-cols-3 gap-6">
            {related.map((s) => (
              <StoryCard
                href={`/stories/${s.id}`}
                title={s.data.title}
                excerpt={s.data.excerpt}
                category={s.data.category}
                date={s.data.date}
                cover={s.data.cover}
                coverAlt={s.data.coverAlt}
              />
            ))}
          </div>
        </div>
      )
    }
  </article>
</BaseLayout>
