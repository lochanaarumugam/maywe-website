---
import BaseLayout from '../layouts/BaseLayout.astro';
import { forms, whatsappLink } from '../config';

const eligibility = [
  'Girls only, aged 14–21',
  'Family income under ₹2 lakh / year',
  'Tribal / SC / OBC or rural background',
  'Minimum 60% in the last exam',
  'Currently studying in India',
];

const faqs = [
  { q: 'Who is eligible?', a: 'Girls aged 14–21 studying in India, with at least 60% in their last exam and a family income under ₹2 lakh a year. Priority is given to tribal, SC/OBC and rural applicants.' },
  { q: 'What documents are needed?', a: 'Latest marksheet, an income certificate, a caste/tribe certificate (if applicable) and a recent photograph. You can upload PDF, JPG or PNG files (up to 5MB each).' },
  { q: 'When will I hear back?', a: 'Applications are reviewed after the deadline. Shortlisted applicants are contacted directly, and results are announced as noted in the scholarship details.' },
  { q: 'Can boys apply?', a: 'MayWe scholarships support girls only, in line with our mission to empower rural and tribal girls.' },
  { q: 'How is my personal data handled?', a: 'Your documents are accessible only to our review team and are deleted after the selection cycle closes. We never publish applicant documents. See our Privacy Policy for details.' },
];

const tallyConfigured = forms.scholarshipTallyId && !forms.scholarshipTallyId.startsWith('REPLACE');
const tallySrc = `https://tally.so/embed/${forms.scholarshipTallyId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`;
const waHref = whatsappLink('Hi MayWe, I have a question about the Scholarship.');
---

<BaseLayout title="Apply for Scholarship" description="Apply for a MayWe merit-based scholarship for rural and tribal girls in India. See eligibility, documents and deadlines." whatsapp={true}>
  <section class="bg-gradient-to-r from-teal-500 to-green-700 text-white">
    <div class="max-w-7xl mx-auto px-4 py-14 md:py-20">
      <h1 class="text-4xl md:text-5xl text-white">Apply for a Scholarship</h1>
      <p class="mt-4 text-white/90 text-lg">Merit-based support for bright girls who can't afford to keep learning.</p>
      <p class="mt-4 text-sm text-white/85">Deadline: 30 June 2026 &nbsp;·&nbsp; Results: August 2026</p>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16 grid lg:grid-cols-3 gap-10 items-start">
      <!-- FORM + ELIGIBILITY -->
      <div class="lg:col-span-2">
        <div class="bg-green-50 rounded-xl p-6 mb-8">
          <h2 class="text-xl mb-3">Eligibility</h2>
          <ul class="space-y-2">
            {eligibility.map((e) => (
              <li class="flex gap-2 text-ink/85"><span class="text-green-700 font-bold" aria-hidden="true">✓</span><span>{e}</span></li>
            ))}
          </ul>
        </div>

        <h2 class="text-2xl mb-4">Application form</h2>
        {
          tallyConfigured ? (
            <iframe
              src={tallySrc}
              title="MayWe scholarship application form"
              loading="lazy"
              width="100%"
              height="1200"
              frameborder="0"
              class="w-full rounded-xl border border-black/10"
            />
          ) : (
            <div class="border-2 border-dashed border-green-700/40 rounded-xl p-8 text-center bg-white">
              <p class="text-ink/80 mb-2">The application form will appear here once connected.</p>
              <p class="text-sm text-muted mb-4">
                Set up a free form at <a href="https://tally.so" class="underline" rel="noopener" target="_blank">tally.so</a> (file uploads, no applicant login), then paste its ID into <code>scholarshipTallyId</code> in <code>src/config.ts</code>.
              </p>
              <a href={waHref} target="_blank" rel="noopener" class="inline-flex items-center gap-2 bg-green-700 text-white font-semibold px-5 py-3 rounded-lg min-h-[44px]">
                Ask us on WhatsApp
              </a>
            </div>
          )
        }
        <p class="mt-3 text-xs text-muted">A confirmation email is sent automatically when you submit. Uploaded documents are deleted after the selection cycle closes.</p>
      </div>

      <!-- SIDEBAR: DETAILS + FAQ -->
      <aside class="space-y-8">
        <div class="bg-white rounded-xl p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-lg mb-3">Scholarship details</h3>
          <ul class="text-sm text-ink/85 space-y-1">
            <li><strong>Amount:</strong> up to ₹12,000 / year (sample)</li>
            <li><strong>Deadline:</strong> 30 June 2026</li>
            <li><strong>Results:</strong> August 2026</li>
          </ul>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-[var(--shadow-card)]">
          <h3 class="text-lg mb-3">Frequently asked questions</h3>
          <div class="divide-y divide-black/10">
            {
              faqs.map((f) => (
                <details class="py-3 group">
                  <summary class="cursor-pointer font-medium text-ink list-none flex justify-between items-center gap-2">
                    <span>{f.q}</span>
                    <span class="text-green-700 group-open:rotate-45 transition-transform" aria-hidden="true">+</span>
                  </summary>
                  <p class="mt-2 text-sm text-ink/80">{f.a}</p>
                </details>
              ))
            }
          </div>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
