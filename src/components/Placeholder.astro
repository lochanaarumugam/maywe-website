---
/**
 * Visual placeholder for images the NGO hasn't supplied yet.
 * Renders a real <img> only if the file actually exists (or is an external URL);
 * otherwise a labelled gradient box. So you can point at canonical names like
 * `/images/hero.webp` and the photo appears the moment you drop the file in.
 */
import { hasPublicImage } from '../lib/images';

interface Props {
  src?: string;
  alt?: string;
  label?: string;
  ratio?: string; // e.g. '16/9', '4/3', '1/1'
  class?: string;
}
const { src, alt = '', label = 'Image', ratio = '16/9', class: cls = '' } = Astro.props;
const showImage = hasPublicImage(src);
---

{
  showImage ? (
    <img
      src={src}
      alt={alt}
      loading="lazy"
      decoding="async"
      class={`w-full h-full object-cover ${cls}`}
      style={`aspect-ratio:${ratio}`}
    />
  ) : (
    <div
      class={`ph w-full rounded-xl ${cls}`}
      style={`aspect-ratio:${ratio}`}
      role="img"
      aria-label={alt || label}
    >
      {label}
    </div>
  )
}
