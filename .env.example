# ─────────────────────────────────────────────────────────────
# MayWe website — environment variables
# Copy this file to `.env` and fill in real values.
# These are PUBLIC values (shipped to the browser), so only put
# non-secret, client-safe keys here. Web3Forms access keys are
# designed to be public.
# ─────────────────────────────────────────────────────────────

# Web3Forms access key — get a free one at https://web3forms.com
# Used by Contact, Volunteer, and CSR inquiry forms.
PUBLIC_WEB3FORMS_KEY=REPLACE_WITH_WEB3FORMS_ACCESS_KEY

# Brevo newsletter form action URL (embed form) — optional.
# Found in Brevo > Contacts > Forms > share/embed.
PUBLIC_NEWSLETTER_ACTION=REPLACE_WITH_BREVO_FORM_URL
