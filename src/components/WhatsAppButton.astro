---
import { whatsappLink } from '../config';
interface Props {
  message?: string;
}
const { message = 'Hi MayWe, I have a question.' } = Astro.props;
const href = whatsappLink(message);
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  aria-label="Chat with us on WhatsApp"
  class="fixed bottom-5 right-5 z-40 inline-flex items-center gap-2 bg-[#25D366] text-white font-semibold pl-4 pr-5 py-3 rounded-full shadow-lg hover:brightness-95 transition min-h-[44px]"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.945C.16 5.335 5.495 0 12.05 0a11.82 11.82 0 018.413 3.488 11.82 11.82 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.51 5.26l-.999 3.648 3.978-1.115zm5.391-6.422c-.197-.099-1.17-.578-1.351-.644-.182-.066-.314-.099-.446.099-.132.198-.51.644-.626.776-.115.132-.231.149-.429.05-.197-.099-.833-.307-1.587-.978-.586-.523-.982-1.17-1.097-1.368-.115-.198-.012-.305.087-.404.089-.088.197-.231.296-.347.099-.116.132-.198.198-.33.066-.132.033-.248-.016-.347-.05-.099-.446-1.075-.612-1.471-.161-.386-.324-.334-.446-.34l-.38-.007a.73.73 0 00-.529.248c-.182.198-.694.678-.694 1.654 0 .976.711 1.918.81 2.05.099.132 1.4 2.138 3.392 2.998.474.205.844.327 1.132.419.476.151.909.13 1.251.079.382-.057 1.17-.478 1.335-.94.165-.462.165-.858.116-.94-.049-.083-.182-.132-.38-.231z"
