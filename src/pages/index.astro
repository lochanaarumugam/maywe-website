---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ImpactCounters from '../components/ImpactCounters.astro';
import StoryCard from '../components/StoryCard.astro';
import Placeholder from '../components/Placeholder.astro';
import { site } from '../config';

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);

const stories = (await getCollection('stories'))
  .filter((s) => !s.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const readMin = (body = '') => Math.max(1, Math.round(body.split(/\s+/).length / 200));
const amounts = [500, 1000, 2500, 5000];
const ctaLabel: Record<string, string> = {
  donate: 'Learn more',
  scholarship: 'Apply now',
  volunteer: 'Volunteer',
};
const ctaHref: Record<string, string> = {
  donate: '/programs',
  scholarship: '/scholarship',
  volunteer: '/volunteer',
};
---

<BaseLayout>
  <!-- HERO -->
  <section class="relative bg-green-50">
    <div class="max-w-7xl mx-auto px-4 py-16 md:py-24 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl text-ink">{site.tagline}</h1>
        <p class="mt-6 text-lg md:text-xl text-ink/80 max-w-xl">
          MayWe provides hygiene infrastructure and scholarships to tribal and rural
          girls in India — so a clean, safe school and a bright future are not a
          privilege, but the norm.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <Button href="/donate" variant="accent">Donate Now</Button>
          <Button href="/impact" variant="outline">Our Impact →</Button>
        </div>
      </div>
      <div class="reveal">
        <Placeholder label="Hero photo — girls in a classroom" alt="Rural schoolgirls in a classroom" ratio="4/3" class="shadow-[var(--shadow-card)]" />
      </div>
    </div>
  </section>

  <!-- IMPACT COUNTERS -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <SectionHeading eyebrow="Our impact so far" title="Numbers behind the mission" class="mb-10" />
      <ImpactCounters />
      <p class="mt-6 text-center">
        <a href="/impact" class="font-semibold text-green-700 hover:text-green-900">See the full impact →</a>
      </p>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section class="bg-green-50">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <SectionHeading eyebrow="What we do" title="Our programs" class="mb-10" />
      <div class="grid md:grid-cols-3 gap-6">
        {
          programs.map((p) => (
            <div class="reveal flex flex-col bg-white rounded-xl p-7 shadow-[var(--shadow-card)] transition-transform hover:-translate-y-1">
              <div class="text-4xl mb-4" aria-hidden="true">{p.data.icon}</div>
              <h3 class="text-xl mb-2">{p.data.title}</h3>
              <p class="text-ink/80 flex-1">{p.data.summary}</p>
              <div class="mt-5">
                <a href={ctaHref[p.data.cta]} class="font-semibold text-green-700 hover:text-green-900">
                  {ctaLabel[p.data.cta]} →
                </a>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- LATEST STORIES -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <SectionHeading eyebrow="From the field" title="Latest stories" class="mb-10" />
      <div class="grid md:grid-cols-3 gap-6">
        {
          stories.map((s) => (
            <StoryCard
              href={`/stories/${s.id}`}
              title={s.data.title}
              excerpt={s.data.excerpt}
              category={s.data.category}
              date={s.data.date}
              cover={s.data.cover}
              coverAlt={s.data.coverAlt}
              readMin={readMin(s.body)}
            />
          ))
        }
      </div>
      <p class="mt-10 text-center">
        <Button href="/stories" variant="outline">View all stories →</Button>
      </p>
    </div>
  </section>

  <!-- DONATE CTA -->
  <section class="bg-green-900 text-white">
    <div class="max-w-4xl mx-auto px-4 py-16 text-center">
      <h2 class="text-3xl md:text-4xl text-white">Help a girl stay in school.</h2>
      <p class="mt-4 text-white/85 text-lg">Choose an amount — every rupee stays in India, close to the girls.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        {
          amounts.map((a) => (
            <a
              href="/donate"
              class="border-2 border-white/70 hover:bg-white hover:text-green-900 text-white font-semibold rounded-lg px-6 py-3 transition min-h-[44px] inline-flex items-center"
            >
              ₹{a.toLocaleString('en-IN')}
            </a>
          ))
        }
      </div>
      <div class="mt-8">
        <Button href="/donate" variant="accent">Donate Now →</Button>
      </div>
    </div>
  </section>

  <!-- VOLUNTEER STRIP -->
  <section class="bg-saffron-100">
    <div class="max-w-7xl mx-auto px-4 py-10 flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
      <p class="text-lg font-semibold text-ink">Share your expertise. Change a life.</p>
      <Button href="/volunteer" variant="primary">Become a Mentor →</Button>
    </div>
  </section>
</BaseLayout>
