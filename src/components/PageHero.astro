---
interface Props {
  title: string;
  subtitle?: string;
  meta?: string;
  variant?: 'green' | 'dark' | 'teal' | 'saffron';
}
const { title, subtitle, meta, variant = 'green' } = Astro.props;
const bg: Record<string, string> = {
  green: 'bg-green-700',
  dark: 'bg-green-900',
  teal: 'bg-teal-500',
  saffron: 'bg-gradient-to-r from-saffron-700 to-green-700',
};
---

<section class={`${bg[variant]} text-white`}>
  <div class="max-w-7xl mx-auto px-4 py-14 md:py-20">
    <h1 class="text-4xl md:text-5xl text-white max-w-3xl">{title}</h1>
    {subtitle && <p class="mt-4 text-lg md:text-xl text-white/90 max-w-2xl">{subtitle}</p>}
    {meta && <p class="mt-4 text-sm text-white/80">{meta}</p>}
  </div>
</section>
