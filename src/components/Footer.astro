---
import { site, contact, social, legal, nav, shown } from '../config';
import NewsletterForm from './NewsletterForm.astro';

interface Props {
  hideNewsletter?: boolean;
}
const { hideNewsletter = false } = Astro.props;
const year = 2026; // build-time constant; bump in a yearly content review

const socialLinks = [
  { label: 'Instagram', href: social.instagram },
  { label: 'Facebook', href: social.facebook },
  { label: 'Twitter/X', href: social.twitter },
  { label: 'LinkedIn', href: social.linkedin },
  { label: 'YouTube', href: social.youtube },
].filter((s) => s.href);

const getInvolved = [
  { label: 'Donate', href: '/donate' },
  { label: 'Apply for Scholarship', href: '/scholarship' },
  { label: 'Volunteer / Mentor', href: '/volunteer' },
  { label: 'Partner with Us (CSR)', href: '/partner' },
];
---

<footer class="mt-20">
  {
    !hideNewsletter && (
      <section class="bg-green-50">
        <div class="max-w-7xl mx-auto px-4 py-12 flex flex-col items-center text-center gap-4">
          <h2 class="text-2xl">Stay connected with MayWe's work</h2>
          <p class="text-muted max-w-lg">
            Field stories, impact updates and ways to help — a few times a year, never spam.
          </p>
          <NewsletterForm />
        </div>
      </section>
    )
  }

  <div class="bg-green-900 text-green-50">
    <div class="max-w-7xl mx-auto px-4 py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-2 font-display text-2xl font-bold text-white mb-3">
          <img src="/images/logo-white.svg" alt="MayWe" width="32" height="32" />
          <span>MayWe</span>
        </div>
        <p class="text-sm text-green-100/90">{site.tagline}</p>
        {
          socialLinks.length > 0 && (
            <ul class="flex flex-wrap gap-3 mt-4 text-sm">
              {socialLinks.map((s) => (
                <li>
                  <a href={s.href} class="hover:text-white underline" rel="noopener" target="_blank">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <nav aria-label="Footer">
        <h3 class="font-semibold text-white mb-3 text-base">Explore</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white">Home</a></li>
          {nav.map((i) => <li><a href={i.href} class="hover:text-white">{i.label}</a></li>)}
        </ul>
      </nav>

      <nav aria-label="Get involved">
        <h3 class="font-semibold text-white mb-3 text-base">Get involved</h3>
        <ul class="space-y-2 text-sm">
          {getInvolved.map((i) => <li><a href={i.href} class="hover:text-white">{i.label}</a></li>)}
        </ul>
      </nav>

      <div>
        <h3 class="font-semibold text-white mb-3 text-base">Reach us</h3>
        <ul class="space-y-2 text-sm">
          <li>✉ <a href={`mailto:${contact.email}`} class="hover:text-white">{contact.email}</a></li>
          <li>📍 {contact.location}</li>
          <li class="pt-2">
            <a href="/donate" class="inline-flex bg-saffron-700 text-white font-semibold px-4 py-2 rounded-lg hover:brightness-95">Donate Now</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10">
      <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row gap-2 sm:items-center sm:justify-between text-xs text-green-100/80">
        <p>
          Reg No: {shown(legal.registrationNo)} &nbsp;|&nbsp; PAN: {shown(legal.pan)} &nbsp;|&nbsp; 80G: {shown(legal.reg80G)}
        </p>
        <p>
          © {year} {site.name} &nbsp;·&nbsp;
          <a href="/privacy" class="hover:text-white underline">Privacy</a> &nbsp;·&nbsp;
          <a href="/terms" class="hover:text-white underline">Terms</a>
        </p>
      </div>
    </div>
  </div>
</footer>
