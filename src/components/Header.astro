---
import { nav, announcement, donate } from '../config';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header id="site-header" class="sticky top-0 z-40 bg-white transition-shadow">
  {
    announcement.text && (
      <div class="bg-green-900 text-white text-sm">
        <div class="max-w-7xl mx-auto px-4 py-2 text-center">
          <span>{announcement.text}</span>
          {announcement.href && (
            <a href={announcement.href} class="underline font-semibold ml-2 hover:text-green-100">
              {announcement.cta} →
            </a>
          )}
        </div>
      </div>
    )
  }

  <div class="border-b border-black/5">
    <nav class="max-w-7xl mx-auto px-4 flex items-center justify-between h-16" aria-label="Primary">
      <a href="/" class="flex items-center gap-2 font-display text-2xl font-bold text-green-700">
        <img src="/images/logo.svg" alt="MayWe" width="36" height="36" />
        <span>MayWe</span>
      </a>

      <ul class="hidden lg:flex items-center gap-7">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'font-medium hover:text-green-700 transition-colors',
                  isActive(item.href) ? 'text-green-700' : 'text-ink',
                ]}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        <a
          href="/donate"
          class="hidden sm:inline-flex items-center bg-saffron-700 text-white font-semibold px-5 py-2.5 rounded-lg hover:brightness-95 transition min-h-[44px]"
          >Donate</a
        >
        <button
          id="nav-toggle"
          class="lg:hidden p-2 -mr-2 text-ink min-h-[44px] min-w-[44px]"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-drawer"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-drawer"
    class="fixed inset-0 z-50 hidden lg:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
  >
    <div id="drawer-overlay" class="absolute inset-0 bg-black/40"></div>
    <div
      class="absolute right-0 top-0 h-full w-72 max-w-[80%] bg-white shadow-xl p-6 flex flex-col gap-1"
    >
      <button id="nav-close" class="self-end p-2 mb-2 min-h-[44px] min-w-[44px]" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
      {
        nav.map((item) => (
          <a href={item.href} class="py-3 text-lg font-medium text-ink hover:text-green-700 border-b border-black/5">
            {item.label}
          </a>
        ))
      }
      <a
        href="/donate"
        class="mt-4 inline-flex items-center justify-center bg-saffron-700 text-white font-semibold px-5 py-3 rounded-lg"
        >Donate</a
      >
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const close = document.getElementById('nav-close');
  const overlay = document.getElementById('drawer-overlay');

  const open = () => {
    drawer?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const shut = () => {
    drawer?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  overlay?.addEventListener('click', shut);
  document.addEventListener('keydown', (e) => e.key === 'Escape' && shut());

  // Sticky header shadow after scroll
  const onScroll = () => {
    if (window.scrollY > 80) header?.classList.add('shadow-md');
    else header?.classList.remove('shadow-md');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
