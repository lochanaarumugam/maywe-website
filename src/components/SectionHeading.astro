---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  class?: string;
}
const { eyebrow, title, subtitle, align = 'center', class: cls = '' } = Astro.props;
const alignCls = align === 'center' ? 'text-center mx-auto items-center' : 'text-left items-start';
---

<div class={`max-w-2xl flex flex-col ${alignCls} ${cls}`}>
  {eyebrow && <span class="kicker mb-4">{eyebrow}</span>}
  <h2 class="text-[2rem] md:text-[2.6rem] leading-[1.05] text-ink">{title}</h2>
  {subtitle && <p class="mt-4 text-lg text-muted max-w-xl">{subtitle}</p>}
</div>
