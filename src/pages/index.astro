---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ImpactCounters from '../components/ImpactCounters.astro';
import StoryCard from '../components/StoryCard.astro';
import Placeholder from '../components/Placeholder.astro';
import impact from '../data/impact.json';

const programs = (await getCollection('programs')).sort((a, b) => a.data.order - b.data.order);

const stories = (await getCollection('stories'))
  .filter((s) => !s.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const readMin = (body = '') => Math.max(1, Math.round(body.split(/\s+/).length / 200));
const amounts = [500, 1000, 2500, 5000];
const headline = impact.counters[0];
const ctaLabel: Record<string, string> = {
  donate: 'Learn more',
  scholarship: 'Apply now',
  volunteer: 'Volunteer',
};
const ctaHref: Record<string, string> = {
  donate: '/programs',
  scholarship: '/scholarship',
  volunteer: '/volunteer',
};
---

<BaseLayout>
  <!-- HERO -->
  <section class="hero-wash relative overflow-hidden">
    <div class="max-w-7xl mx-auto px-4 pt-14 md:pt-20 pb-20 md:pb-28 grid lg:grid-cols-[1.05fr_0.95fr] gap-12 lg:gap-16 items-center">
      <div class="hero-stagger">
        <span class="kicker">Hygiene &amp; education for rural girls</span>
        <h1 class="mt-5 font-display text-[2.9rem] sm:text-6xl lg:text-[4.1rem] leading-[1.02] text-ink">
          Every girl deserves to <span class="italic text-green-700">stay in school.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-ink/75 max-w-xl leading-relaxed">
          MayWe builds clean toilets and safe water in tribal and rural schools, and funds
          scholarships for bright girls — so a dignified school and a future are the norm,
          not a privilege.
        </p>
        <div class="mt-9 flex flex-wrap gap-4">
          <Button href="/donate" variant="accent">Donate Now</Button>
          <Button href="/impact" variant="outline">See our impact →</Button>
        </div>
        <p class="mt-7 text-sm text-muted flex items-center gap-2">
          <span class="text-green-700" aria-hidden="true">●</span>
          Tax-deductible under 80G · 100% of our work is in India
        </p>
      </div>

      <div class="hero-art relative mx-auto w-full max-w-[420px] lg:mr-0">
        <!-- block-print dot motif, top-right -->
        <div
          class="absolute -top-6 -right-2 w-28 h-20 opacity-70 hidden sm:block"
          style="background-image:radial-gradient(var(--color-marigold) 24%, transparent 26%); background-size:15px 15px"
          aria-hidden="true"
        ></div>
        <!-- teal seed cluster, bottom-right behind -->
        <div class="absolute -z-0 -bottom-8 right-2 w-24 h-24 rounded-full bg-teal-500/15 blur-xl" aria-hidden="true"></div>

        <!-- offset arch (depth) -->
        <div
          class="absolute inset-0 translate-x-3 translate-y-3 bg-gradient-to-br from-marigold/35 via-saffron-700/15 to-teal-500/25"
          style="border-radius:48% 48% 1.6rem 1.6rem / 56% 56% 1.6rem 1.6rem"
          aria-hidden="true"
        ></div>

        <!-- arched image frame -->
        <div
          class="relative overflow-hidden shadow-[var(--shadow-card)] ring-1 ring-black/5 bg-paper"
          style="border-radius:48% 48% 1.6rem 1.6rem / 56% 56% 1.6rem 1.6rem"
        >
          <Placeholder src="/images/hero.webp" label="Hero photo — girls at school" alt="Building a school for rural girls" ratio="4/5" />
          <!-- warm wash to seat the photo in the palette -->
          <div class="absolute inset-0 bg-gradient-to-t from-green-900/35 via-transparent to-transparent" aria-hidden="true"></div>
        </div>

        <!-- sprout mark -->
        <svg class="absolute top-4 left-4 w-9 h-9 text-marigold drop-shadow" viewBox="0 0 48 48" fill="currentColor" aria-hidden="true">
          <path d="M24 44c0-9-3-15-10-18 8-1 13 3 15 10 2-9 6-13 13-13-5 5-7 11-7 21z" />
        </svg>

        <!-- floating stat chip -->
        <div class="absolute -bottom-4 -left-3 sm:-left-7 card px-5 py-3.5 flex items-center gap-3 -rotate-2">
          <span class="font-display text-3xl font-semibold text-green-700">
            {headline.value.toLocaleString('en-IN')}{headline.suffix}
          </span>
          <span class="text-[0.7rem] font-bold uppercase tracking-wider text-muted leading-tight max-w-[5rem]">
            {headline.label}
          </span>
        </div>
      </div>
    </div>
  </section>

  <!-- IMPACT COUNTERS -->
  <section>
    <div class="max-w-7xl mx-auto px-4 py-20">
      <SectionHeading eyebrow="Our impact so far" title="Numbers behind the mission" class="mb-12" />
      <ImpactCounters />
      <p class="mt-8 text-center">
        <a href="/impact" class="font-semibold text-green-700 hover:text-green-900 underline underline-offset-4 decoration-marigold/50">See the full impact →</a>
      </p>
    </div>
  </section>

  <!-- PROGRAMS -->
  <section class="bg-cream border-y border-[rgba(54,38,18,0.06)]">
    <div class="max-w-7xl mx-auto px-4 py-20">
      <SectionHeading eyebrow="What we do" title="Three connected programs" subtitle="Keeping bright rural girls in school takes more than one thing." class="mb-12" />
      <div class="grid md:grid-cols-3 gap-6">
        {
          programs.map((p) => (
            <div class="reveal card group flex flex-col p-8 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_24px_44px_-22px_rgba(54,38,18,0.4)]">
              <div class="w-14 h-14 rounded-2xl bg-green-50 flex items-center justify-center text-3xl mb-5" aria-hidden="true">{p.data.icon}</div>
              <h3 class="font-display text-2xl mb-3">{p.data.title}</h3>
              <p class="text-ink/75 leading-relaxed flex-1">{p.data.summary}</p>
              <a href={ctaHref[p.data.cta]} class="mt-6 inline-flex items-center gap-1.5 font-semibold text-green-700 group-hover:gap-2.5 transition-all">
                {ctaLabel[p.data.cta]} <span aria-hidden="true">→</span>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- LATEST STORIES -->
  <section>
    <div class="max-w-7xl mx-auto px-4 py-20">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-6 mb-12">
        <SectionHeading align="left" eyebrow="From the field" title="Latest stories" />
        <a href="/stories" class="hidden sm:inline-flex items-center gap-1.5 font-semibold text-green-700 hover:gap-2.5 transition-all whitespace-nowrap">View all stories <span aria-hidden="true">→</span></a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {
          stories.map((s) => (
            <StoryCard
              href={`/stories/${s.id}`}
              title={s.data.title}
              excerpt={s.data.excerpt}
              category={s.data.category}
              date={s.data.date}
              cover={s.data.cover}
              coverAlt={s.data.coverAlt}
              readMin={readMin(s.body)}
            />
          ))
        }
      </div>
      <p class="mt-12 text-center sm:hidden">
        <Button href="/stories" variant="outline">View all stories →</Button>
      </p>
    </div>
  </section>

  <!-- DONATE CTA -->
  <section class="panel-deep">
    <div class="max-w-4xl mx-auto px-4 py-20 text-center">
      <span class="kicker mb-5" style="color:#f2c98a">Your gift, their future</span>
      <h2 class="font-display text-4xl md:text-5xl leading-tight">Help a girl stay in school.</h2>
      <p class="mt-5 text-[#f4ead8]/85 text-lg">Every rupee stays in India, close to the girls. Pick an amount to begin.</p>
      <div class="mt-9 flex flex-wrap justify-center gap-3">
        {
          amounts.map((a) => (
            <a
              href="/donate"
              class="border border-white/40 hover:border-marigold hover:bg-marigold/15 text-white font-semibold rounded-full px-7 py-3 transition-all min-h-[46px] inline-flex items-center"
            >
              ₹{a.toLocaleString('en-IN')}
            </a>
          ))
        }
      </div>
      <div class="mt-9">
        <Button href="/donate" variant="accent">Donate Now →</Button>
      </div>
    </div>
  </section>

  <!-- VOLUNTEER STRIP -->
  <section class="bg-saffron-100">
    <div class="max-w-7xl mx-auto px-4 py-12 flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-4 text-center">
      <p class="font-display text-2xl text-ink">Share your expertise. Change a life.</p>
      <Button href="/volunteer" variant="primary">Become a Mentor →</Button>
    </div>
  </section>
</BaseLayout>
