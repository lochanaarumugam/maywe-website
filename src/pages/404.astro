---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page not found">
  <section class="bg-white">
    <div class="max-w-2xl mx-auto px-4 py-24 text-center">
      <p class="text-6xl font-display font-bold text-green-700">404</p>
      <h1 class="text-3xl mt-4">This page wandered off.</h1>
      <p class="mt-4 text-ink/80">The page you're looking for doesn't exist or has moved.</p>
      <div class="mt-8 flex flex-wrap gap-4 justify-center">
        <Button href="/" variant="primary">Back to home</Button>
        <Button href="/donate" variant="accent">Donate →</Button>
      </div>
    </div>
  </section>
</BaseLayout>
