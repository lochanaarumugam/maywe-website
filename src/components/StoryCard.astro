---
import Placeholder from './Placeholder.astro';

interface Props {
  href: string;
  title: string;
  excerpt: string;
  category: string;
  date: Date;
  cover?: string;
  coverAlt?: string;
  readMin?: number;
}
const { href, title, excerpt, category, date, cover, coverAlt, readMin } = Astro.props;
const dateStr = date.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
---

<article
  class="reveal group card flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_24px_44px_-22px_rgba(54,38,18,0.4)]"
>
  <a href={href} class="block overflow-hidden">
    <div class="transition-transform duration-500 group-hover:scale-[1.05]">
      <Placeholder src={cover} alt={coverAlt ?? title} label="Story photo" ratio="16/9" />
    </div>
  </a>
  <div class="flex flex-col flex-1 p-6">
    <span
      class="self-start text-[0.68rem] font-bold uppercase tracking-[0.1em] text-saffron-700 bg-saffron-100 rounded-full px-3 py-1 mb-4"
      >{category}</span
    >
    <h3 class="font-display text-[1.4rem] leading-snug mb-2">
      <a href={href} class="transition-colors hover:text-green-700">{title}</a>
    </h3>
    <p class="text-xs font-medium uppercase tracking-wider text-muted mb-3">
      {dateStr}{readMin ? ` · ${readMin} min read` : ''}
    </p>
    <p class="text-ink/75 mb-5 flex-1 leading-relaxed">{excerpt}</p>
    <a href={href} class="inline-flex items-center gap-1.5 font-semibold text-green-700 group-hover:gap-2.5 transition-all">
      Read more <span aria-hidden="true">→</span>
    </a>
  </div>
</article>
