---
import { nav, announcement } from '../config';
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<!-- top accent bar -->
<div class="h-1 bg-gradient-to-r from-marigold via-saffron-700 to-teal-500"></div>

<header id="site-header" class="sticky top-0 z-40 transition-shadow">
  {
    announcement.text && (
      <div class="bg-green-900 text-[#f4ead8] text-sm">
        <div class="max-w-7xl mx-auto px-4 py-2 text-center">
          <span class="text-marigold" aria-hidden="true">✦</span>{' '}
          <span>{announcement.text}</span>
          {announcement.href && (
            <a href={announcement.href} class="underline underline-offset-2 font-semibold ml-1 text-white hover:text-marigold">
              {announcement.cta} →
            </a>
          )}
        </div>
      </div>
    )
  }

  <div class="bg-[#faf6ee]/85 backdrop-blur-md border-b border-[rgba(54,38,18,0.1)]">
    <nav class="max-w-7xl mx-auto px-4 flex items-center justify-between h-[68px]" aria-label="Primary">
      <a href="/" class="flex items-center gap-2.5 font-display text-2xl font-semibold text-green-900 tracking-tight">
        <img src="/images/logo.svg" alt="MayWe" width="38" height="38" />
        <span>MayWe</span>
      </a>

      <ul class="hidden lg:flex items-center gap-8">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  'relative py-1.5 text-[0.95rem] font-medium transition-colors hover:text-green-700',
                  isActive(item.href) ? 'text-green-700' : 'text-ink',
                ]}
              >
                {item.label}
                {isActive(item.href) && (
                  <span class="absolute -bottom-0.5 left-0 right-0 h-0.5 rounded-full bg-gradient-to-r from-marigold to-saffron-700" />
                )}
              </a>
            </li>
          ))
        }
      </ul>

      <div class="flex items-center gap-3">
        <a
          href="/donate"
          class="hidden sm:inline-flex items-center bg-saffron-700 text-white font-semibold text-[0.95rem] px-6 py-2.5 rounded-full hover:brightness-110 hover:-translate-y-0.5 transition-all shadow-[var(--shadow-soft)] min-h-[44px]"
          >Donate</a
        >
        <button
          id="nav-toggle"
          class="lg:hidden p-2 -mr-2 text-ink min-h-[44px] min-w-[44px]"
          aria-label="Open menu"
          aria-expanded="false"
          aria-controls="mobile-drawer"
        >
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </button>
      </div>
    </nav>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-drawer"
    class="fixed inset-0 z-50 hidden lg:hidden"
    role="dialog"
    aria-modal="true"
    aria-label="Menu"
  >
    <div id="drawer-overlay" class="absolute inset-0 bg-green-900/50 backdrop-blur-sm"></div>
    <div
      class="absolute right-0 top-0 h-full w-72 max-w-[80%] bg-paper shadow-xl p-6 flex flex-col gap-1"
    >
      <button id="nav-close" class="self-end p-2 mb-2 min-h-[44px] min-w-[44px] text-ink" aria-label="Close menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="6" y1="6" x2="18" y2="18"></line>
          <line x1="18" y1="6" x2="6" y2="18"></line>
        </svg>
      </button>
      {
        nav.map((item) => (
          <a href={item.href} class="py-3 text-lg font-medium text-ink hover:text-green-700 border-b border-[rgba(54,38,18,0.08)]">
            {item.label}
          </a>
        ))
      }
      <a
        href="/donate"
        class="mt-5 inline-flex items-center justify-center bg-saffron-700 text-white font-semibold px-5 py-3 rounded-full"
        >Donate</a
      >
    </div>
  </div>
</header>

<script>
  const header = document.getElementById('site-header');
  const toggle = document.getElementById('nav-toggle');
  const drawer = document.getElementById('mobile-drawer');
  const close = document.getElementById('nav-close');
  const overlay = document.getElementById('drawer-overlay');

  const open = () => {
    drawer?.classList.remove('hidden');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  };
  const shut = () => {
    drawer?.classList.add('hidden');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  };

  toggle?.addEventListener('click', open);
  close?.addEventListener('click', shut);
  overlay?.addEventListener('click', shut);
  document.addEventListener('keydown', (e) => e.key === 'Escape' && shut());

  const onScroll = () => {
    if (window.scrollY > 60) header?.classList.add('shadow-lg');
    else header?.classList.remove('shadow-lg');
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
