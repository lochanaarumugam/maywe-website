---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Placeholder from '../components/Placeholder.astro';
import { legal, shown } from '../config';

const team = (await getCollection('team')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="About" description="MayWe's story, team and registrations — a not-for-profit for hygiene and girls' education in rural India.">
  <PageHero title="About MayWe" subtitle="Our story, our team, our commitment." />

  <!-- OUR STORY -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-10 items-center">
      <div class="reveal">
        <SectionHeading align="left" eyebrow="Our story" title="Why MayWe exists" class="mb-5" />
        <div class="space-y-4 text-ink/85">
          <p>
            MayWe is a not-for-profit dedicated to improving hygiene and education
            standards in tribal and rural India, and to empowering economically
            challenged yet academically gifted girls.
          </p>
          <p>
            We work where a missing toilet or an unaffordable exam fee quietly ends
            a girl's schooling. By building hygiene infrastructure and funding
            merit-based scholarships — backed by mentorship and life-skills training
            — we help bright rural girls stay in school and pursue higher education
            and leadership.
          </p>
          <p class="text-sm text-muted">
            <em>Replace this section with MayWe's real founding story (300–400 words).</em>
          </p>
        </div>
      </div>
      <div class="reveal">
        <Placeholder src="/images/about-story.webp" label="Founders / program photo" alt="MayWe founders with students" ratio="4/3" class="shadow-[var(--shadow-card)]" />
        <p class="mt-2 text-xs text-muted">Photos of minors are published only with written guardian consent.</p>
      </div>
    </div>
  </section>

  <!-- MISSION & VISION -->
  <section class="bg-green-50">
    <div class="max-w-7xl mx-auto px-4 py-16 grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-xl p-8 shadow-[var(--shadow-card)]">
        <h3 class="text-2xl text-green-700 mb-3">Mission</h3>
        <p class="text-ink/85">
          To enhance academic and hygiene infrastructure in tribal/rural areas, and
          to provide scholarships, mentorship and life-skill training to bright girls
          from low-income families.
        </p>
      </div>
      <div class="bg-white rounded-xl p-8 shadow-[var(--shadow-card)]">
        <h3 class="text-2xl text-green-700 mb-3">Vision</h3>
        <p class="text-ink/85">
          Every tribal and rural girl child grows up in a clean, dignified
          environment, nurtures her skills, and flourishes academically — with the
          financial assistance she needs to achieve her goals.
        </p>
      </div>
    </div>
  </section>

  <!-- OUR TEAM -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-4 py-16">
      <SectionHeading eyebrow="The people" title="Our team" class="mb-10" />
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {
          team.map((m) => (
            <div class="reveal bg-white rounded-xl p-6 text-center shadow-[var(--shadow-card)]">
              <div class="w-28 h-28 mx-auto mb-4 rounded-full overflow-hidden">
                <Placeholder src={m.data.photo} label="Photo" alt={m.data.name} ratio="1/1" />
              </div>
              <h3 class="text-lg">{m.data.name}</h3>
              <p class="text-sm font-semibold text-green-700">{m.data.role}</p>
              <p class="mt-3 text-sm text-ink/80">{m.data.bio}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- LEGAL & REGISTRATIONS -->
  <section class="bg-green-50">
    <div class="max-w-3xl mx-auto px-4 py-16">
      <SectionHeading eyebrow="Transparency" title="Legal & registrations" class="mb-8" />
      <div class="bg-white rounded-xl p-8 shadow-[var(--shadow-card)] text-center space-y-2">
        <p><strong>Registration No:</strong> {shown(legal.registrationNo)}</p>
        <p><strong>PAN:</strong> {shown(legal.pan)} &nbsp;·&nbsp; <strong>80G No:</strong> {shown(legal.reg80G)} &nbsp;·&nbsp; <strong>12A No:</strong> {shown(legal.reg12A)}</p>
        <p>{legal.entityType}</p>
        <p>Registered in {shown(legal.registeredState, '[State]')}, India</p>
      </div>
    </div>
  </section>
</BaseLayout>
