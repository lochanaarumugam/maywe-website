---
import impact from '../data/impact.json';

interface Props {
  size?: 'normal' | 'large';
  class?: string;
}
const { size = 'normal', class: cls = '' } = Astro.props;
const numCls = size === 'large' ? 'text-5xl md:text-6xl' : 'text-4xl md:text-5xl';
---

<div class={`grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-5 ${cls}`} data-impact-counters>
  {
    impact.counters.map((c) => (
      <div class="reveal card relative overflow-hidden p-6 md:p-7 text-center">
        <span class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-marigold to-saffron-700" />
        <div class="text-xl mb-2 opacity-80" aria-hidden="true">{c.icon}</div>
        <div
          class={`font-display font-semibold leading-none ${numCls}`}
          data-target={c.value}
          data-format={c.format}
          data-suffix={c.suffix}
          style="color:#1f6b45"
        >
          0
        </div>
        <div class="mt-3 text-[0.72rem] font-bold uppercase tracking-[0.12em] text-muted">{c.label}</div>
      </div>
    ))
  }
</div>

<script>
  function formatINR(n: number): string {
    // Indian grouping: ₹32,00,000
    return '₹' + n.toLocaleString('en-IN');
  }

  function animate(el: HTMLElement) {
    const target = Number(el.dataset.target || '0');
    const format = el.dataset.format || 'plain';
    const suffix = el.dataset.suffix || '';
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const render = (val: number) => {
      const rounded = Math.round(val);
      el.textContent = (format === 'inr' ? formatINR(rounded) : rounded.toLocaleString('en-IN')) + suffix;
    };
    if (reduce) {
      render(target);
      return;
    }
    const duration = 1600;
    const start = performance.now();
    const step = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3); // easeOutCubic
      render(target * eased);
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  document.querySelectorAll('[data-impact-counters]').forEach((group) => {
    const nums = group.querySelectorAll<HTMLElement>('[data-target]');
    if (!('IntersectionObserver' in window)) {
      nums.forEach(animate);
      return;
    }
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            animate(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        }
      },
      { threshold: 0.4 }
    );
    nums.forEach((n) => io.observe(n));
  });
</script>
