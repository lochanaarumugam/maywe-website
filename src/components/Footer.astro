---
import { site, contact, social, legal, nav, shown } from '../config';
import NewsletterForm from './NewsletterForm.astro';

interface Props {
  hideNewsletter?: boolean;
}
const { hideNewsletter = false } = Astro.props;
const year = 2026; // build-time constant; bump in a yearly content review

const socialLinks = [
  { label: 'Instagram', href: social.instagram },
  { label: 'Facebook', href: social.facebook },
  { label: 'Twitter/X', href: social.twitter },
  { label: 'LinkedIn', href: social.linkedin },
  { label: 'YouTube', href: social.youtube },
].filter((s) => s.href);

const getInvolved = [
  { label: 'Donate', href: '/donate' },
  { label: 'Apply for Scholarship', href: '/scholarship' },
  { label: 'Volunteer / Mentor', href: '/volunteer' },
  { label: 'Partner with Us (CSR)', href: '/partner' },
];
---

<footer class="mt-24">
  {
    !hideNewsletter && (
      <section class="bg-cream border-t border-[rgba(54,38,18,0.08)]">
        <div class="max-w-3xl mx-auto px-4 py-16 flex flex-col items-center text-center gap-5">
          <span class="kicker">Newsletter</span>
          <h2 class="font-display text-[2rem] md:text-4xl leading-tight">Stay connected with MayWe's work</h2>
          <p class="text-muted max-w-lg">
            Field stories, impact updates and ways to help — a few times a year, never spam.
          </p>
          <NewsletterForm />
        </div>
      </section>
    )
  }

  <div class="panel-deep">
    <div class="max-w-7xl mx-auto px-4 py-16 grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <div class="sm:col-span-2 lg:col-span-1">
        <div class="flex items-center gap-2.5 font-display text-2xl font-semibold text-white mb-4">
          <img src="/images/logo-white.svg" alt="MayWe" width="34" height="34" />
          <span>MayWe</span>
        </div>
        <p class="text-[0.95rem] text-[#dce8db] leading-relaxed max-w-xs">{site.tagline}</p>
        {
          socialLinks.length > 0 && (
            <ul class="flex flex-wrap gap-x-4 gap-y-2 mt-5 text-sm">
              {socialLinks.map((s) => (
                <li>
                  <a href={s.href} class="text-[#cfe0d4] hover:text-marigold transition-colors" rel="noopener" target="_blank">
                    {s.label}
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </div>

      <nav aria-label="Footer">
        <h3 class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-marigold mb-4">Explore</h3>
        <ul class="space-y-2.5 text-[0.95rem]">
          <li><a href="/" class="text-[#dce8db] hover:text-white transition-colors">Home</a></li>
          {nav.map((i) => <li><a href={i.href} class="text-[#dce8db] hover:text-white transition-colors">{i.label}</a></li>)}
        </ul>
      </nav>

      <nav aria-label="Get involved">
        <h3 class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-marigold mb-4">Get involved</h3>
        <ul class="space-y-2.5 text-[0.95rem]">
          {getInvolved.map((i) => <li><a href={i.href} class="text-[#dce8db] hover:text-white transition-colors">{i.label}</a></li>)}
        </ul>
      </nav>

      <div>
        <h3 class="text-[0.72rem] font-bold uppercase tracking-[0.14em] text-marigold mb-4">Reach us</h3>
        <ul class="space-y-2.5 text-[0.95rem] text-[#dce8db]">
          <li>✉ <a href={`mailto:${contact.email}`} class="hover:text-white transition-colors">{contact.email}</a></li>
          <li>📍 {contact.location}</li>
          <li class="pt-2">
            <a href="/donate" class="inline-flex bg-saffron-700 text-white font-semibold px-5 py-2.5 rounded-full hover:brightness-110 hover:-translate-y-0.5 transition-all">Donate Now</a>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/10">
      <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row gap-2 sm:items-center sm:justify-between text-xs text-[#bcd0bf]">
        <p>
          Reg No: {shown(legal.registrationNo)} &nbsp;|&nbsp; PAN: {shown(legal.pan)} &nbsp;|&nbsp; 80G: {shown(legal.reg80G)}
        </p>
        <p>
          © {year} {site.name} &nbsp;·&nbsp;
          <a href="/privacy" class="hover:text-white underline">Privacy</a> &nbsp;·&nbsp;
          <a href="/terms" class="hover:text-white underline">Terms</a>
        </p>
      </div>
    </div>
  </div>
</footer>
